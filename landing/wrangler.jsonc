{
    "main": "dist/_worker.js/index.js",
    "name": "gsheetbase",
    "compatibility_date": "2026-03-08",
    "compatibility_flags": [
        "nodejs_compat",
        "global_fetch_strictly_public"
    ],
    "assets": {
        "binding": "ASSETS",
        "directory": "./dist"
    },
    "observability": {
        "enabled": true
    },
    "routes": [
        {
            "pattern": "gsheetbase.com/*",
            "custom_domain": true
        }
    ]
}